#2. Используя awk найдите все источники и их сообщения в файле auth.log (найдите его find), в
# названии источника удалите информацию об идентификаторе процесса при помощи sed,
# полученный результат отсортируйте по названию источника


t@eltex-practice2-pg2-v1-13:02> find / -name "auth.log"
/var/log/auth.log

root@eltex-practice2-pg2-v1-13:28> cat /var/log/auth.log | awk '{$1=$2=""; print$0}' | sed 's/\[[^]]*\]//' | sort -k1

