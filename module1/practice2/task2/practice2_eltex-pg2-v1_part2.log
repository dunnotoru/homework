root@eltex-practice2-pg2-v1-09:47> touch practice2_${MYUSER}_part2.log

#1. Найдите все записи из лога загрузки, доступного через команду journalctl с опцией -b в первые
# 20 секунд с момента загрузки, начало загрузки определить автоматически.

#!/bin/bash                                                                                                                                                               
SINCE="$(date -d "$(journalctl -b -o short-iso | head -n 1 | awk '{print $1}')" "+%Y-%m-%d %H:%M:%S")"
UNTIL="$(date -d "$SINCE 20 seconds " "+%Y-%m-%d %H:%M:%S")"
echo $SINCE --- $UNTIL
journalctl -b --since "$SINCE" --until "$UNTIL"

