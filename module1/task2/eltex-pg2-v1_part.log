#10. Создайте переменную DATE, в которую запишите текущую дату. Проверьте содержимое переменной.
eltex-pg2-v1@eltex-2026-spring:~$ DATE=`date +"%d-%m-%Y"`
eltex-pg2-v1@eltex-2026-spring:~$ echo $DATE
07-03-2026

#11. Создайте переменную TIME, в которую запишите текущее время. Проверьте содержимое переменной.
eltex-pg2-v1@eltex-2026-spring:~$ TIME=`date +"%H:%M:%S"`
eltex-pg2-v1@eltex-2026-spring:~$ echo $TIME
01:29:49

#12. Создайте переменную DATE_TIME в которую поместите значения из
переменных DATE и TIME, разделенных пробелом. Проверьте содержимое переменной.
eltex-pg2-v1@eltex-2026-spring:~$ DATE_TIME=$DATE\ $TIME
eltex-pg2-v1@eltex-2026-spring:~$ echo $DATE_TIME
07-03-2026 01:29:49

