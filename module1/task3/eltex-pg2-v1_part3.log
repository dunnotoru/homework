
#2. Создайте иерархию вложенных каталогов D1/D2/D3.

eltex-pg2-v1@eltex-2026-spring-18:16> mkdir -p D1/D2/D3

#3. В каталоге D2 создайте обычный пустой файл file.txt.

eltex-pg2-v1@eltex-2026-spring-18:16> touch D1/D2/file.txt

#4. Добавьте произвольный текст в файл file.txt

eltex-pg2-v1@eltex-2026-spring-18:17> echo 'random text tralala' > D1/D2/file.txt

#5. В каталоге D3 создайте символическую и жесткие ссылки на file.txt.

eltex-pg2-v1@eltex-2026-spring-18:25> ln D1/D2/file.txt D1/D2/D3/hard-file
eltex-pg2-v1@eltex-2026-spring-18:25> ln -s ~/D1/D2/file.txt D1/D2/D3/sym-file

#6 Докажите, что ссылки созданы успешно

eltex-pg2-v1@eltex-2026-spring-18:29> cat D1/D2/file.txt
random text tralala
eltex-pg2-v1@eltex-2026-spring-18:29> cat D1/D2/D3/hard-file
random text tralala
eltex-pg2-v1@eltex-2026-spring-18:44> cat D1/D2/D3/sym-file
random text tralala

#7. Переместите файл file.txt в каталог D1

eltex-pg2-v1@eltex-2026-spring-18:44> mv D1/D2/file.txt D1/

#8. Проверьте работу ранее созданных ссылок на файл file.txt. Какая ссылка оказалась рабочей и почему?
#> При создании жесткой ссылки создается новое имя для того же самого файла, поэтому она остается рабочей.
#> Cимволическая ссылка ломается потому что теперь ссылается на пустое место.

eltex-pg2-v1@eltex-2026-spring-18:45> cat D1/D2/D3/hard-file
random text tralala
eltex-pg2-v1@eltex-2026-spring-21:58> cat D1/D2/D3/sym-file
cat: D1/D2/D3/sym-file: No such file or directory

#9. Удалите каталог D2 со всем содержимым

eltex-pg2-v1@eltex-2026-spring-22:01> rm -r D1/D2
eltex-pg2-v1@eltex-2026-spring-22:01> ls D1/
file.txt

